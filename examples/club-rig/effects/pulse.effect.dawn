effect Pulse {
  param color base = #2244ff;
  param color accent = #ffcc66;
  param float speed = 0.75;
  param curve<float> fade;

  color sample(float progress, float seconds, Fixture fixture, Pixel pixel) {
    float phase = (sin(progress * speed * 9) + 1.0) / 2.0;
    return mix(base, accent, fade(phase));
  }
}

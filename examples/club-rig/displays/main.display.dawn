display MainDisplay {
  label "Main room LED wall and house fixtures";

  controller WallController {
    output artnet {
      universe 1 range 1..510;
      universe 2 range 1..510;
    }
  }

  controller FloorController {
    output sACN {
      universe 11 range 1..510;
      universe 12 range 1..510;
    }
  }
}

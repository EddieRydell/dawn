main:
  type: display
  name: main
  layout:
    import: ../layouts/stage.layout.dawn::stage
  patch:
    import: ../patches/house.patch.dawn::house
  controllers:
    - name: WallController
      protocol: artnet
      universes:
        - id: 1
          range: "1..510"
        - id: 2
          range: "1..510"
    - name: FloorController
      protocol: sacn
      universes:
        - id: 11
          range: "1..510"
        - id: 12
          range: "1..510"

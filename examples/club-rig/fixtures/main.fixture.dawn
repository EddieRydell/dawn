pixel_bar_50:
  type: fixture
  name: PixelBar
  color_model: rgb
  bulb_size: 1.15
  geometry:
    type: lines
    points:
    - x: -0.5
      y: 0.0
      z: 0.0
    - x: 0.5
      y: 0.0
      z: 0.0
    - x: -1.0
      y: 1.0
      z: 0.0
    pixels: 50

spot_rgb:
  type: fixture
  name: Spot
  color_model: rgb
  bulb_size: 1.0
  geometry:
    type: points
    points:
    - x: 0.0
      y: 0.0
      z: 0.0

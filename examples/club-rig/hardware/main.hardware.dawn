hardware MainRig {
  fixture PixelBar {
    channels 150;
    pixel_count 50;
    color rgb;
  }

  fixture Spot {
    channels 16;
    params {
      dimmer int range 0..255;
      pan float range -270..270;
      tilt float range -135..135;
      color color;
    }
  }

  group WallBars {
    members [bar_01, bar_02, bar_03, bar_04];
  }

  group Movers {
    members [spot_01, spot_02, spot_03, spot_04];
  }
}

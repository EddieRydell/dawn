imports:
  - from: ../layouts/house.layout.dawn
    as: layouts
  - from: ../patches/main.patch.dawn
    as: patches

main:
  type: display
  name: Christmas House
  layout: layouts.house
  patch: patches.main
  controllers:
    - name: HouseController
      protocol: artnet
      universes:
        - id: 1
          range: "1..510"
        - id: 2
          range: "1..510"

effect CandyCane {
  param color first = #ff0000;
  param color second = #ffffff;
  param int stripe_pixels = 6;
  param float speed = 1.0;

  color sample(float progress, float seconds, Fixture fixture, Pixel pixel) {
    float stripe = floor((pixel_index(pixel) + seconds * speed * stripe_pixels) / max(1.0, stripe_pixels));
    float even = stripe - floor(stripe / 2.0) * 2.0;
    if (even < 1.0) {
      return first;
    }
    return second;
  }
}

(
    version: 1,
    primitives: [
        "String",
        "Int",
        "Float",
        "Bool",
        "Color",
        "Duration",
        "FrameRate",
        "Path",
        "Identifier",
    ],
    documents: [
        (
            name: "project",
            fields: [
                (name: "version", ty: "String", cardinality: "optional_one"),
                (name: "label", ty: "String", cardinality: "optional_one"),
                (name: "description", ty: "String", cardinality: "optional_one"),
                (name: "display", ty: "Ref<Display>", cardinality: "optional_one"),
                (name: "hardware", ty: "Ref<Hardware>", cardinality: "optional_one"),
                (name: "layout", ty: "Ref<Layout>", cardinality: "optional_one"),
                (name: "patch", ty: "Ref<Patch>", cardinality: "optional_one"),
                (name: "sequence", ty: "SequenceReference", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "display",
            fields: [
                (name: "label", ty: "String", cardinality: "optional_one"),
                (name: "controller", ty: "Controller", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "hardware",
            fields: [
                (name: "fixture", ty: "FixtureType", cardinality: "zero_or_more"),
                (name: "group", ty: "FixtureGroup", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "layout",
            fields: [
                (name: "spatial", ty: "SpatialConfig", cardinality: "optional_one"),
                (name: "fixture", ty: "FixturePlacement", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "patch",
            fields: [
                (name: "route", ty: "Route", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "sequence",
            fields: [
                (name: "duration", ty: "Duration", cardinality: "optional_one"),
                (name: "frame_rate", ty: "FrameRate", cardinality: "optional_one"),
                (name: "audio", ty: "Path", cardinality: "optional_one"),
                (name: "at", ty: "Cue", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "effect",
            fields: [
                (name: "param", ty: "EffectParam", cardinality: "zero_or_more"),
                (name: "fn", ty: "Function", cardinality: "zero_or_more"),
            ],
        ),
    ],
    records: [
        (
            name: "SequenceReference",
            fields: [
                (name: "sequence", ty: "Ref<Sequence>", cardinality: "required_one"),
                (name: "duration", ty: "Duration", cardinality: "optional_one"),
                (name: "frame_rate", ty: "FrameRate", cardinality: "optional_one"),
            ],
        ),
        (
            name: "Controller",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "output", ty: "Output", cardinality: "one_or_more"),
            ],
        ),
        (
            name: "Output",
            fields: [
                (name: "protocol", ty: "Identifier", cardinality: "required_one"),
                (name: "universe", ty: "UniverseRange", cardinality: "one_or_more"),
            ],
        ),
        (
            name: "UniverseRange",
            fields: [
                (name: "universe", ty: "Int", cardinality: "required_one"),
                (name: "range", ty: "Range<Int>", cardinality: "required_one"),
            ],
        ),
        (
            name: "FixtureType",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "channels", ty: "Int", cardinality: "optional_one"),
                (name: "pixel_count", ty: "Int", cardinality: "optional_one"),
                (name: "color", ty: "Identifier", cardinality: "optional_one"),
                (name: "params", ty: "List<FixtureParam>", cardinality: "optional_one"),
            ],
        ),
        (
            name: "FixtureParam",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "ty", ty: "Identifier", cardinality: "required_one"),
                (name: "range", ty: "Range<Float>", cardinality: "optional_one"),
            ],
        ),
        (
            name: "FixtureGroup",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "members", ty: "List<Identifier>", cardinality: "required_one"),
            ],
        ),
        (
            name: "SpatialConfig",
            fields: [
                (name: "units", ty: "Identifier", cardinality: "required_one"),
            ],
        ),
        (
            name: "FixturePlacement",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "position", ty: "Vec3<Float>", cardinality: "required_one"),
                (name: "fixture_type", ty: "Ref<FixtureType>", cardinality: "required_one"),
            ],
        ),
        (
            name: "Route",
            fields: [
                (name: "source", ty: "Ref<FixtureGroup>", cardinality: "required_one"),
                (name: "target", ty: "Ref<Controller>", cardinality: "required_one"),
                (name: "universe", ty: "Int", cardinality: "required_one"),
                (name: "start", ty: "Int", cardinality: "required_one"),
            ],
        ),
        (
            name: "Cue",
            fields: [
                (name: "time", ty: "Duration", cardinality: "required_one"),
                (name: "target", ty: "Ref<FixtureGroup>", cardinality: "optional_one"),
                (name: "effect", ty: "EffectApplication", cardinality: "zero_or_more"),
                (name: "set", ty: "ParamSet", cardinality: "zero_or_more"),
                (name: "animate", ty: "ParamAnimation", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "EffectApplication",
            fields: [
                (name: "effect", ty: "Ref<Effect>", cardinality: "required_one"),
                (name: "params", ty: "List<EffectArgument>", cardinality: "zero_or_more"),
            ],
        ),
        (
            name: "EffectArgument",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "value", ty: "Value", cardinality: "required_one"),
            ],
        ),
        (
            name: "ParamSet",
            fields: [
                (name: "param", ty: "Identifier", cardinality: "required_one"),
                (name: "value", ty: "Value", cardinality: "required_one"),
            ],
        ),
        (
            name: "ParamAnimation",
            fields: [
                (name: "param", ty: "Identifier", cardinality: "required_one"),
                (name: "curve", ty: "Identifier", cardinality: "optional_one"),
                (name: "from", ty: "Value", cardinality: "required_one"),
                (name: "to", ty: "Value", cardinality: "required_one"),
                (name: "duration", ty: "Duration", cardinality: "required_one"),
            ],
        ),
        (
            name: "EffectParam",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "ty", ty: "Identifier", cardinality: "required_one"),
                (name: "default", ty: "Value", cardinality: "optional_one"),
            ],
        ),
        (
            name: "Function",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "params", ty: "List<FunctionParam>", cardinality: "zero_or_more"),
                (name: "body", ty: "Block", cardinality: "required_one"),
            ],
        ),
        (
            name: "FunctionParam",
            fields: [
                (name: "name", ty: "Identifier", cardinality: "required_one"),
                (name: "ty", ty: "Identifier", cardinality: "required_one"),
            ],
        ),
    ],
)

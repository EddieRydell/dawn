(
    version: 2,
    language: (
        type_name: "DawnLanguage",
        syntax_kind: "SyntaxKind",
    ),

    diagnostics: (
        invalid_token: "InvalidToken",
        unexpected_token: "UnexpectedToken",
        unexpected_eof: "UnexpectedEof",
        kinds: [
            (name: "InvalidToken", message: "invalid token"),
            (name: "InvalidColor", message: "invalid color literal"),
            (name: "InvalidInt", message: "invalid integer literal"),
            (name: "InvalidFloat", message: "invalid float literal"),
            (name: "UnterminatedBlockComment", message: "unterminated block comment"),
            (name: "UnexpectedToken", message: "unexpected token"),
            (name: "UnexpectedEof", message: "unexpected end of file"),
        ],
    ),

    tokens: (
        rules: [
            (name: "Whitespace", regex: "[ \\t\\r\\n\\f]+", trivia: skip),
            (name: "LineComment", regex: "//[^\\n]*", trivia: emit),
            (name: "BlockComment", start: "/*", end: "*/", trivia: emit, diagnostic: "UnterminatedBlockComment"),

            (name: "ImportKw", literal: "import"),
            (name: "FromKw", literal: "from"),
            (name: "FnKw", literal: "fn"),
            (name: "LetKw", literal: "let"),
            (name: "TrueKw", literal: "true"),
            (name: "FalseKw", literal: "false"),

            (name: "Ident", regex: "[A-Za-z_][A-Za-z0-9_]*"),
            (name: "String", regex: "\"[^\"]*\""),
            (name: "Color", regex: "#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?"),
            (name: "InvalidColor", regex: "#[0-9A-Za-z]*", diagnostic: "InvalidColor"),
            (name: "Duration", regex: "([0-9][0-9_]*(\\.[0-9_]+)?|\\.[0-9][0-9_]*)[a-zA-Z]+"),
            (name: "Float", regex: "(([0-9][0-9_]*\\.[0-9][0-9_]*|\\.[0-9][0-9_]*)([eE][+-]?[0-9][0-9_]*)?|[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*)"),
            (name: "Int", regex: "[0-9][0-9_]*"),

            (name: "StarStar", literal: "**"),
            (name: "EqEq", literal: "=="),
            (name: "BangEq", literal: "!="),
            (name: "Le", literal: "<="),
            (name: "Ge", literal: ">="),
            (name: "AndAnd", literal: "&&"),
            (name: "OrOr", literal: "||"),
            (name: "Shl", literal: "<<"),
            (name: "Shr", literal: ">>"),
            (name: "DotDot", literal: ".."),
            (name: "LBrace", literal: "{"),
            (name: "RBrace", literal: "}"),
            (name: "LBracket", literal: "["),
            (name: "RBracket", literal: "]"),
            (name: "LParen", literal: "("),
            (name: "RParen", literal: ")"),
            (name: "Lt", literal: "<"),
            (name: "Gt", literal: ">"),
            (name: "Colon", literal: ":"),
            (name: "Comma", literal: ","),
            (name: "Semicolon", literal: ";"),
            (name: "Dot", literal: "."),
            (name: "Eq", literal: "="),
            (name: "Plus", literal: "+"),
            (name: "Minus", literal: "-"),
            (name: "Star", literal: "*"),
            (name: "Slash", literal: "/"),
            (name: "Percent", literal: "%"),
            (name: "Pipe", literal: "|"),
            (name: "Ampersand", literal: "&"),
            (name: "Caret", literal: "^"),
            (name: "Bang", literal: "!"),
            (name: "Question", literal: "?"),
        ],
    ),

    syntax: (
        entry: "SourceFile",
        nodes: [
            "SourceFile", "ImportDecl", "Document", "Block", "Item",
            "Command", "CommandHead", "CommandInitializer",
            "LetStmt", "FnDecl", "ParamList", "Param", "TypeRef",
            "Name", "PathLit",
            "NameRef", "StringLit", "IntLit", "FloatLit", "BoolLit", "ColorLit", "DurationLit",
            "ListExpr", "ParenExpr", "CallArgList",
        ],
        rules: [
            (
                name: "SourceFile",
                pattern: [
                    (label: "imports", repeat: [(node: "ImportDecl")]),
                    (label: "document", node: "Document"),
                ],
            ),
            (
                name: "ImportDecl",
                pattern: [
                    (token: "ImportKw"),
                    (label: "kind", node: "Name"),
                    (label: "name", node: "Name"),
                    (token: "FromKw"),
                    (label: "path", node: "PathLit"),
                    (token: "Semicolon"),
                ],
            ),
            (
                name: "Document",
                pattern: [
                    (label: "kind", node: "Name"),
                    (label: "name", node: "Name"),
                    (label: "block", node: "Block"),
                ],
            ),
            (
                name: "Block",
                pattern: [
                    (token: "LBrace"),
                    (label: "items", repeat: [(node: "Item")]),
                    (token: "RBrace"),
                ],
            ),
            (
                name: "Item",
                pattern: [
                    (label: "kind", enum: "ItemKind", choice: [
                        (node: "FnDecl"),
                        (node: "LetStmt"),
                        (node: "Command"),
                    ]),
                ],
            ),
            (
                name: "FnDecl",
                pattern: [
                    (token: "FnKw"),
                    (label: "name", node: "Name"),
                    (label: "params", node: "ParamList"),
                    (label: "return_type", optional: [(node: "TypeRef")]),
                    (label: "body", node: "Block"),
                ],
            ),
            (
                name: "ParamList",
                pattern: [
                    (token: "LParen"),
                    (label: "params", repeat: [
                        (node: "Param"),
                        (optional: [(token: "Comma")]),
                    ]),
                    (token: "RParen"),
                ],
            ),
            (
                name: "Param",
                pattern: [
                    (label: "name", node: "Name"),
                    (label: "ty", optional: [(node: "TypeRef")]),
                ],
            ),
            (
                name: "LetStmt",
                pattern: [
                    (token: "LetKw"),
                    (label: "name", node: "Name"),
                    (label: "ty", optional: [(node: "TypeRef")]),
                    (label: "value", optional: [(token: "Eq"), (expr: "Expr")]),
                    (token: "Semicolon"),
                ],
            ),
            (
                name: "Command",
                pattern: [
                    (label: "head", node: "CommandHead"),
                    (label: "args", repeat: [(expr: "Expr")]),
                    (label: "initializer", optional: [(node: "CommandInitializer")]),
                    (choice: [
                        (label: "body", node: "Block"),
                        (token: "Semicolon"),
                    ]),
                ],
            ),
            (
                name: "CommandHead",
                pattern: [(label: "name", node: "Name")],
            ),
            (
                name: "CommandInitializer",
                pattern: [
                    (token: "Eq"),
                    (label: "value", expr: "Expr"),
                ],
            ),
            (name: "TypeRef", pattern: [(label: "name", node: "Name")]),
            (name: "Name", pattern: [(choice: [(token: "Ident"), (token: "FromKw")])]),
            (
                name: "PathLit",
                pattern: [
                    (token: "Lt"),
                    (label: "tokens", repeat: [(token_set: "PathToken")]),
                    (token: "Gt"),
                ],
            ),
            (name: "NameRef", pattern: [(label: "name", node: "Name")]),
            (name: "StringLit", pattern: [(label: "token", token: "String")]),
            (name: "IntLit", pattern: [(label: "token", token: "Int")]),
            (name: "FloatLit", pattern: [(label: "token", token: "Float")]),
            (name: "BoolLit", pattern: [(label: "token", choice: [(token: "TrueKw"), (token: "FalseKw")])]),
            (name: "ColorLit", pattern: [(label: "token", token: "Color")]),
            (name: "DurationLit", pattern: [(label: "token", token: "Duration")]),
            (
                name: "ListExpr",
                pattern: [
                    (token: "LBracket"),
                    (label: "items", repeat: [
                        (expr: "Expr"),
                        (optional: [(token: "Comma")]),
                    ]),
                    (token: "RBracket"),
                ],
            ),
            (
                name: "ParenExpr",
                pattern: [
                    (token: "LParen"),
                    (label: "expr", expr: "Expr"),
                    (token: "RParen"),
                ],
            ),
            (
                name: "CallArgList",
                pattern: [
                    (token: "LParen"),
                    (label: "args", repeat: [
                        (expr: "Expr"),
                        (optional: [(token: "Comma")]),
                    ]),
                    (token: "RParen"),
                ],
            ),
        ],
        token_sets: [
            (
                name: "PathToken",
                include: "all_tokens",
                exclude: ["Lt", "Gt"],
            ),
        ],
    ),

    expressions: (
        items: [
            (
                name: "Expr",
                root_node: "Expr",
                atoms: [
                    (node: "NameRef"),
                    (node: "StringLit"),
                    (node: "IntLit"),
                    (node: "FloatLit"),
                    (node: "BoolLit"),
                    (node: "ColorLit"),
                    (node: "DurationLit"),
                    (node: "ListExpr"),
                    (node: "ParenExpr"),
                ],
                prefix: [
                    (token: "Minus", node: "PrefixExpr"),
                    (token: "Bang", node: "PrefixExpr"),
                ],
                infix: [
                    (token: "OrOr", node: "BinaryExpr", precedence: "LogicalOr", associativity: "left"),
                    (token: "AndAnd", node: "BinaryExpr", precedence: "LogicalAnd", associativity: "left"),
                    (token: "Pipe", node: "BinaryExpr", precedence: "BitOr", associativity: "left"),
                    (token: "Caret", node: "BinaryExpr", precedence: "BitXor", associativity: "left"),
                    (token: "Ampersand", node: "BinaryExpr", precedence: "BitAnd", associativity: "left"),
                    (token: "EqEq", node: "BinaryExpr", precedence: "Equality", associativity: "left"),
                    (token: "BangEq", node: "BinaryExpr", precedence: "Equality", associativity: "left"),
                    (token: "Lt", node: "BinaryExpr", precedence: "Compare", associativity: "left"),
                    (token: "Le", node: "BinaryExpr", precedence: "Compare", associativity: "left"),
                    (token: "Gt", node: "BinaryExpr", precedence: "Compare", associativity: "left"),
                    (token: "Ge", node: "BinaryExpr", precedence: "Compare", associativity: "left"),
                    (token: "DotDot", node: "BinaryExpr", precedence: "Range", associativity: "left"),
                    (token: "Shl", node: "BinaryExpr", precedence: "Shift", associativity: "left"),
                    (token: "Shr", node: "BinaryExpr", precedence: "Shift", associativity: "left"),
                    (token: "Plus", node: "BinaryExpr", precedence: "Add", associativity: "left"),
                    (token: "Minus", node: "BinaryExpr", precedence: "Add", associativity: "left"),
                    (token: "Star", node: "BinaryExpr", precedence: "Mul", associativity: "left"),
                    (token: "Slash", node: "BinaryExpr", precedence: "Mul", associativity: "left"),
                    (token: "Percent", node: "BinaryExpr", precedence: "Mul", associativity: "left"),
                    (token: "StarStar", node: "BinaryExpr", precedence: "Power", associativity: "right"),
                ],
                postfix: [
                    (
                        node: "CallExpr",
                        pattern: [
                            (node: "CallArgList"),
                        ],
                    ),
                ],
            ),
        ],
    ),

    ast: (
        root: "SourceFile",
        nodes: [],
    ),
)

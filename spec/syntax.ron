(
    language: (
        type_name: "DawnLanguage",
        syntax_kind: "SyntaxKind",
    ),

    diagnostics: (
        invalid_token: "InvalidToken",
        unexpected_token: "UnexpectedToken",
        unexpected_eof: "UnexpectedEof",
        kinds: [
            (name: "InvalidToken", message: "invalid token"),
            (name: "InvalidColor", message: "invalid color literal"),
            (name: "InvalidInt", message: "invalid integer literal"),
            (name: "InvalidFloat", message: "invalid float literal"),
            (name: "UnterminatedBlockComment", message: "unterminated block comment"),
            (name: "UnexpectedToken", message: "unexpected token"),
            (name: "UnexpectedEof", message: "unexpected end of file"),
        ],
    ),

    tokens: (
        rules: [
            (name: "Whitespace", regex: "[ \\t\\r\\n\\f]+", trivia: skip),
            (name: "LineComment", regex: "//[^\\n]*", trivia: emit),
            (name: "BlockComment", start: "/*", end: "*/", trivia: emit, diagnostic: "UnterminatedBlockComment"),

            (name: "ImportKw", literal: "import"),
            (name: "FromKw", literal: "from"),
            (name: "FnKw", literal: "fn"),
            (name: "LetKw", literal: "let"),
            (name: "IfKw", literal: "if"),
            (name: "ElseKw", literal: "else"),
            (name: "SwitchKw", literal: "switch"),
            (name: "CaseKw", literal: "case"),
            (name: "DefaultKw", literal: "default"),
            (name: "ForKw", literal: "for"),
            (name: "TrueKw", literal: "true"),
            (name: "FalseKw", literal: "false"),

            (name: "Ident", regex: "[A-Za-z_][A-Za-z0-9_]*"),
            (name: "String", regex: "\"[^\"]*\""),
            (name: "Color", regex: "#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?"),
            (name: "InvalidColor", regex: "#[0-9A-Za-z]*", diagnostic: "InvalidColor"),
            (name: "Float", regex: "(([0-9][0-9_]*\\.[0-9_]*|\\.[0-9][0-9_]*)([eE][+-]?[0-9][0-9_]*)?|[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*)"),
            (name: "Int", regex: "[0-9][0-9_]*"),

            (name: "StarStar", literal: "**"),
            (name: "EqEq", literal: "=="),
            (name: "BangEq", literal: "!="),
            (name: "Le", literal: "<="),
            (name: "Ge", literal: ">="),
            (name: "AndAnd", literal: "&&"),
            (name: "OrOr", literal: "||"),
            (name: "Shl", literal: "<<"),
            (name: "Shr", literal: ">>"),
            (name: "LBrace", literal: "{"),
            (name: "RBrace", literal: "}"),
            (name: "LBracket", literal: "["),
            (name: "RBracket", literal: "]"),
            (name: "LParen", literal: "("),
            (name: "RParen", literal: ")"),
            (name: "Lt", literal: "<"),
            (name: "Gt", literal: ">"),
            (name: "Colon", literal: ":"),
            (name: "Comma", literal: ","),
            (name: "Semicolon", literal: ";"),
            (name: "Dot", literal: "."),
            (name: "Eq", literal: "="),
            (name: "Plus", literal: "+"),
            (name: "Minus", literal: "-"),
            (name: "Star", literal: "*"),
            (name: "Slash", literal: "/"),
            (name: "Percent", literal: "%"),
            (name: "Pipe", literal: "|"),
            (name: "Ampersand", literal: "&"),
            (name: "Caret", literal: "^"),
            (name: "Bang", literal: "!"),
            (name: "Question", literal: "?"),
        ],
    ),

    syntax: (
        entry: "SourceFile",
        nodes: [
            "SourceFile",
            "ImportDecl",
            "Document",
            "DocKind",
            "Name",
            "PathLit",
            "DocumentBody",
            "BodyItem",
            "Stmt",
            "StmtHead",
            "BalancedBlock",
            "BalancedItem",
        ],
        rules: [
            (
                name: "SourceFile",
                pattern: [
                    (repeat: "ImportDecl"),
                    (node: "Document"),
                ],
            ),
            (
                name: "ImportDecl",
                pattern: [
                    (token: "ImportKw"),
                    (node: "DocKind"),
                    (node: "Name"),
                    (token: "FromKw"),
                    (node: "PathLit"),
                    (token: "Semicolon"),
                ],
            ),
            (
                name: "Document",
                pattern: [
                    (node: "DocKind"),
                    (node: "Name"),
                    (node: "DocumentBody"),
                ],
            ),
            (
                name: "DocKind",
                pattern: [(token: "Ident")],
            ),
            (
                name: "StmtHead",
                pattern: [
                    (choice: [
                        (token: "Ident"),
                        (token: "FnKw"),
                        (token: "LetKw"),
                        (token: "IfKw"),
                        (token: "ElseKw"),
                        (token: "SwitchKw"),
                        (token: "CaseKw"),
                        (token: "DefaultKw"),
                        (token: "ForKw"),
                    ]),
                ],
            ),
            (name: "Name", pattern: [(token: "Ident")]),
            (
                name: "PathLit",
                pattern: [
                    (token: "Lt"),
                    (repeat: "PathToken"),
                    (token: "Gt"),
                ],
            ),
            (
                name: "DocumentBody",
                pattern: [
                    (token: "LBrace"),
                    (repeat: "BodyItem"),
                    (token: "RBrace"),
                ],
            ),
            (
                name: "BodyItem",
                pattern: [
                    (choice: [
                        (node: "Stmt"),
                        (node: "BalancedBlock"),
                    ]),
                ],
            ),
            (
                name: "Stmt",
                pattern: [
                    (node: "StmtHead"),
                    (repeat: "HeaderToken"),
                    (choice: [
                        (node: "DocumentBody"),
                        (token: "Semicolon"),
                    ]),
                ],
            ),
            (
                name: "BalancedBlock",
                pattern: [
                    (token: "LBrace"),
                    (repeat: "BalancedItem"),
                    (token: "RBrace"),
                ],
            ),
            (
                name: "BalancedItem",
                pattern: [
                    (choice: [
                        (node: "BalancedBlock"),
                        (token_set: "AnyTokenExceptBrace"),
                    ]),
                ],
            ),
        ],
        token_sets: [
            (
                name: "PathToken",
                include: "all_tokens",
                exclude: ["Lt", "Gt"],
            ),
            (
                name: "HeaderToken",
                include: "all_tokens",
                exclude: ["LBrace", "RBrace", "Semicolon"],
            ),
            (
                name: "AnyTokenExceptBrace",
                include: "all_tokens",
                exclude: ["LBrace", "RBrace"],
            ),
        ],
    ),

    expressions: (
        items: [],
    ),

    ast: (
        root: "SourceFile",
        nodes: [
            (
                name: "SourceFile",
                syntax: "SourceFile",
                accessors: [
                    (name: "imports", kind: "children", node: "ImportDecl"),
                    (name: "document", kind: "child", node: "Document"),
                ],
            ),
            (
                name: "ImportDecl",
                syntax: "ImportDecl",
                accessors: [
                    (name: "kind", kind: "child", node: "DocKind"),
                    (name: "name", kind: "child", node: "Name"),
                    (name: "path", kind: "child", node: "PathLit"),
                ],
            ),
            (
                name: "Document",
                syntax: "Document",
                accessors: [
                    (name: "kind", kind: "child", node: "DocKind"),
                    (name: "name", kind: "child", node: "Name"),
                    (name: "body", kind: "child", node: "DocumentBody"),
                    (name: "block", kind: "child", node: "DocumentBody"),
                ],
            ),
            (
                name: "DocKind",
                syntax: "DocKind",
                accessors: [
                    (name: "token", kind: "first_token"),
                    (name: "text", kind: "first_token_text"),
                ],
            ),
            (
                name: "Name",
                syntax: "Name",
                accessors: [
                    (name: "ident", kind: "token", token: "Ident"),
                    (name: "text", kind: "token_text", token: "Ident"),
                ],
            ),
            (
                name: "PathLit",
                syntax: "PathLit",
                accessors: [(name: "raw_text", kind: "text_between", start: "Lt", end: "Gt")],
            ),
            (
                name: "DocumentBody",
                syntax: "DocumentBody",
                accessors: [
                    (name: "items", kind: "children", node: "BodyItem"),
                ],
            ),
            (
                name: "BodyItem",
                syntax: "BodyItem",
                accessors: [
                    (name: "stmt", kind: "child", node: "Stmt"),
                    (name: "block", kind: "child", node: "BalancedBlock"),
                    (name: "variant", kind: "child_enum", enum: "BodyItemKind"),
                ],
            ),
            (
                name: "Stmt",
                syntax: "Stmt",
                accessors: [
                    (name: "head", kind: "child", node: "StmtHead"),
                    (name: "header_tokens", kind: "tokens", token_set: "HeaderToken"),
                    (name: "body", kind: "child", node: "DocumentBody"),
                ],
            ),
            (
                name: "StmtHead",
                syntax: "StmtHead",
                accessors: [
                    (name: "token", kind: "first_token"),
                    (name: "text", kind: "first_token_text"),
                ],
            ),
            (
                name: "BalancedBlock",
                syntax: "BalancedBlock",
                accessors: [(name: "items", kind: "children", node: "BalancedItem")],
            ),
            (
                name: "BalancedItem",
                syntax: "BalancedItem",
                accessors: [],
            ),
        ],
        enums: [
            (
                name: "BodyItemKind",
                kind: "node",
                from_node: "BodyItem",
                variants: [
                    ("Stmt", "Stmt"),
                    ("BalancedBlock", "BalancedBlock"),
                ],
            ),
        ],
    ),
)

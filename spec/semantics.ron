(
    version: 1,
    root: "SourceFile",
    hir: [
        (name: "SourceFile", kind: struct, source: "SourceFile", fields: [
            (name: "imports", ty: "Vec<Import>"),
            (name: "document", ty: "Document"),
        ]),
        (name: "Import", kind: struct, source: "ImportDecl", fields: [
            (name: "kind", ty: "Ident"),
            (name: "name", ty: "Ident"),
            (name: "path", ty: "PathLiteral"),
        ]),
        (name: "Document", kind: struct, source: "Document", fields: [
            (name: "kind", ty: "Ident"),
            (name: "name", ty: "Ident"),
            (name: "block", ty: "Block"),
        ]),
        (name: "Block", kind: struct, source: "Block", fields: [
            (name: "items", ty: "Vec<Item>"),
        ]),
        (name: "Item", kind: enum, variants: [
            (name: "FnDecl", ty: "FnDecl"),
            (name: "LetStmt", ty: "LetStmt"),
            (name: "Command", ty: "Command"),
        ]),
        (name: "FnDecl", kind: struct, source: "FnDecl", fields: [
            (name: "name", ty: "Ident"),
            (name: "params", ty: "Vec<Param>"),
            (name: "return_type", ty: "Option<TypeRef>"),
            (name: "body", ty: "Block"),
        ]),
        (name: "Param", kind: struct, source: "Param", fields: [
            (name: "name", ty: "Ident"),
            (name: "ty", ty: "Option<TypeRef>"),
        ]),
        (name: "LetStmt", kind: struct, source: "LetStmt", fields: [
            (name: "name", ty: "Ident"),
            (name: "ty", ty: "Option<TypeRef>"),
            (name: "value", ty: "Option<Expr>"),
        ]),
        (name: "Command", kind: struct, source: "Command", fields: [
            (name: "name", ty: "Ident"),
            (name: "args", ty: "Vec<Expr>"),
            (name: "initializer", ty: "Option<Expr>"),
            (name: "body", ty: "Option<Block>"),
        ]),
        (name: "TypeRef", kind: struct, source: "TypeRef", fields: [(name: "name", ty: "Ident")]),
        (name: "Ident", kind: struct, source: "Name", fields: [(name: "text", ty: "String")]),
        (name: "PathLiteral", kind: struct, source: "PathLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "Expr", kind: enum, variants: [
            (name: "NameRef", ty: "NameRef"),
            (name: "Literal", ty: "Literal"),
            (name: "List", ty: "List"),
            (name: "Paren", ty: "Paren"),
            (name: "Call", ty: "Call"),
            (name: "Prefix", ty: "Prefix"),
            (name: "Binary", ty: "Binary"),
        ]),
        (name: "NameRef", kind: struct, source: "NameRef", fields: [(name: "name", ty: "Ident")]),
        (name: "Literal", kind: enum, variants: [
            (name: "String", ty: "StringLiteral"),
            (name: "Int", ty: "IntLiteral"),
            (name: "Float", ty: "FloatLiteral"),
            (name: "Bool", ty: "BoolLiteral"),
            (name: "Color", ty: "ColorLiteral"),
            (name: "Duration", ty: "DurationLiteral"),
        ]),
        (name: "StringLiteral", kind: struct, source: "StringLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "IntLiteral", kind: struct, source: "IntLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "FloatLiteral", kind: struct, source: "FloatLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "ColorLiteral", kind: struct, source: "ColorLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "DurationLiteral", kind: struct, source: "DurationLit", fields: [(name: "raw_text", ty: "String")]),
        (name: "BoolLiteral", kind: struct, source: "BoolLit", fields: [(name: "value", ty: "bool")]),
        (name: "List", kind: struct, source: "ListExpr", fields: [(name: "items", ty: "Vec<Expr>")]),
        (name: "Paren", kind: struct, source: "ParenExpr", fields: [(name: "expr", ty: "Box<Expr>")]),
        (name: "Call", kind: struct, source: "CallExpr", fields: [
            (name: "callee", ty: "Box<Expr>"),
            (name: "args", ty: "Vec<Expr>"),
        ]),
        (name: "Prefix", kind: struct, source: "PrefixExpr", fields: [
            (name: "op", ty: "PrefixOp"),
            (name: "expr", ty: "Box<Expr>"),
        ]),
        (name: "Binary", kind: struct, source: "BinaryExpr", fields: [
            (name: "left", ty: "Box<Expr>"),
            (name: "op", ty: "BinaryOp"),
            (name: "right", ty: "Box<Expr>"),
        ]),
        (name: "PrefixOp", kind: enum, variants: [
            (name: "Neg"),
            (name: "Not"),
        ]),
        (name: "BinaryOp", kind: enum, variants: [
            (name: "LogicalOr"),
            (name: "LogicalAnd"),
            (name: "BitOr"),
            (name: "BitXor"),
            (name: "BitAnd"),
            (name: "Eq"),
            (name: "NotEq"),
            (name: "Lt"),
            (name: "Le"),
            (name: "Gt"),
            (name: "Ge"),
            (name: "Range"),
            (name: "Shl"),
            (name: "Shr"),
            (name: "Add"),
            (name: "Sub"),
            (name: "Mul"),
            (name: "Div"),
            (name: "Rem"),
            (name: "Pow"),
        ]),
    ],
    lower: [
        (syntax: "SourceFile", hir: "SourceFile", fields: [
            (name: "imports", accessor: "imports"),
            (name: "document", accessor: "document"),
        ]),
        (syntax: "ImportDecl", hir: "Import", fields: [
            (name: "kind", accessor: "kind"),
            (name: "name", accessor: "name"),
            (name: "path", accessor: "path"),
        ]),
        (syntax: "Document", hir: "Document", fields: [
            (name: "kind", accessor: "kind"),
            (name: "name", accessor: "name"),
            (name: "block", accessor: "block"),
        ]),
        (syntax: "Block", hir: "Block", fields: [(name: "items", accessor: "items")]),
        (syntax: "Item", hir: "Item", dispatch: "kind", variants: [
            (syntax: "FnDecl", target: "FnDecl"),
            (syntax: "LetStmt", target: "LetStmt"),
            (syntax: "Command", target: "Command"),
        ]),
        (syntax: "FnDecl", hir: "FnDecl", fields: [
            (name: "name", accessor: "name"),
            (name: "params", accessor: "params.params"),
            (name: "return_type", accessor: "return_type"),
            (name: "body", accessor: "body"),
        ]),
        (syntax: "Param", hir: "Param", fields: [
            (name: "name", accessor: "name"),
            (name: "ty", accessor: "ty"),
        ]),
        (syntax: "LetStmt", hir: "LetStmt", fields: [
            (name: "name", accessor: "name"),
            (name: "ty", accessor: "ty"),
            (name: "value", accessor: "value"),
        ]),
        (syntax: "Command", hir: "Command", fields: [
            (name: "name", accessor: "head.name"),
            (name: "args", accessor: "args"),
            (name: "initializer", accessor: "initializer.value"),
            (name: "body", accessor: "body"),
        ]),
        (syntax: "TypeRef", hir: "TypeRef", fields: [(name: "name", accessor: "name")]),
        (syntax: "Name", hir: "Ident", fields: [(name: "text", accessor: "text", scalar: "text")]),
        (syntax: "PathLit", hir: "PathLiteral", fields: [(name: "raw_text", accessor: "raw_text", scalar: "raw_text")]),
        (syntax: "Expr", hir: "Expr", dispatch: "kind", variants: [
            (syntax: "NameRef", target: "NameRef"),
            (syntax: "StringLit", target: "Literal::String"),
            (syntax: "IntLit", target: "Literal::Int"),
            (syntax: "FloatLit", target: "Literal::Float"),
            (syntax: "BoolLit", target: "Literal::Bool"),
            (syntax: "ColorLit", target: "Literal::Color"),
            (syntax: "DurationLit", target: "Literal::Duration"),
            (syntax: "ListExpr", target: "List"),
            (syntax: "ParenExpr", target: "Paren"),
            (syntax: "CallExpr", target: "Call"),
            (syntax: "PrefixExpr", target: "Prefix"),
            (syntax: "BinaryExpr", target: "Binary"),
        ]),
        (syntax: "NameRef", hir: "NameRef", fields: [(name: "name", accessor: "name")]),
        (syntax: "StringLit", hir: "StringLiteral", fields: [(name: "raw_text", accessor: "text", scalar: "text")]),
        (syntax: "IntLit", hir: "IntLiteral", fields: [(name: "raw_text", accessor: "text", scalar: "text")]),
        (syntax: "FloatLit", hir: "FloatLiteral", fields: [(name: "raw_text", accessor: "text", scalar: "text")]),
        (syntax: "ColorLit", hir: "ColorLiteral", fields: [(name: "raw_text", accessor: "text", scalar: "text")]),
        (syntax: "DurationLit", hir: "DurationLiteral", fields: [(name: "raw_text", accessor: "text", scalar: "text")]),
        (syntax: "BoolLit", hir: "BoolLiteral", fields: [(name: "value", accessor: "text", scalar: "bool")]),
        (syntax: "ListExpr", hir: "List", fields: [(name: "items", accessor: "items")]),
        (syntax: "ParenExpr", hir: "Paren", fields: [(name: "expr", accessor: "expr")]),
        (syntax: "CallExpr", hir: "Call", fields: [
            (name: "callee", accessor: "callee"),
            (name: "args", accessor: "args"),
        ]),
        (syntax: "PrefixExpr", hir: "Prefix", fields: [
            (name: "op", accessor: "op", scalar: "operator(prefix)"),
            (name: "expr", accessor: "expr"),
        ]),
        (syntax: "BinaryExpr", hir: "Binary", fields: [
            (name: "left", accessor: "left"),
            (name: "op", accessor: "op", scalar: "operator(binary)"),
            (name: "right", accessor: "right"),
        ]),
    ],
    operators: (
        prefix: [
            (token: "Minus", variant: "Neg"),
            (token: "Bang", variant: "Not"),
        ],
        binary: [
            (token: "OrOr", variant: "LogicalOr"),
            (token: "AndAnd", variant: "LogicalAnd"),
            (token: "Pipe", variant: "BitOr"),
            (token: "Caret", variant: "BitXor"),
            (token: "Ampersand", variant: "BitAnd"),
            (token: "EqEq", variant: "Eq"),
            (token: "BangEq", variant: "NotEq"),
            (token: "Lt", variant: "Lt"),
            (token: "Le", variant: "Le"),
            (token: "Gt", variant: "Gt"),
            (token: "Ge", variant: "Ge"),
            (token: "DotDot", variant: "Range"),
            (token: "Shl", variant: "Shl"),
            (token: "Shr", variant: "Shr"),
            (token: "Plus", variant: "Add"),
            (token: "Minus", variant: "Sub"),
            (token: "Star", variant: "Mul"),
            (token: "Slash", variant: "Div"),
            (token: "Percent", variant: "Rem"),
            (token: "StarStar", variant: "Pow"),
        ],
    ),
)

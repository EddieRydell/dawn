(
    version: 1,
    root: "SourceFile",
    hir: [
        (name: "SourceFile", kind: struct, fields: [
            (name: "imports", ty: "Vec<Import>"),
            (name: "document", ty: "Document"),
        ]),
        (name: "Import", kind: struct, fields: [
            (name: "kind", ty: "Ident"),
            (name: "name", ty: "Ident"),
            (name: "path", ty: "PathLiteral"),
        ]),
        (name: "Document", kind: struct, fields: [
            (name: "kind", ty: "Ident"),
            (name: "name", ty: "Ident"),
            (name: "block", ty: "Block"),
        ]),
        (name: "Block", kind: struct, fields: [
            (name: "items", ty: "Vec<Item>"),
        ]),
        (name: "Item", kind: enum, variants: [
            (name: "FnDecl", ty: "FnDecl"),
            (name: "LetStmt", ty: "LetStmt"),
            (name: "Command", ty: "Command"),
        ]),
        (name: "FnDecl", kind: struct, fields: [
            (name: "name", ty: "Ident"),
            (name: "params", ty: "Vec<Param>"),
            (name: "return_type", ty: "Option<TypeRef>"),
            (name: "body", ty: "Block"),
        ]),
        (name: "Param", kind: struct, fields: [
            (name: "name", ty: "Ident"),
            (name: "ty", ty: "Option<TypeRef>"),
        ]),
        (name: "LetStmt", kind: struct, fields: [
            (name: "name", ty: "Ident"),
            (name: "ty", ty: "Option<TypeRef>"),
            (name: "value", ty: "Option<Expr>"),
        ]),
        (name: "Command", kind: struct, fields: [
            (name: "name", ty: "Ident"),
            (name: "args", ty: "Vec<Expr>"),
            (name: "initializer", ty: "Option<Expr>"),
            (name: "body", ty: "Option<Block>"),
        ]),
        (name: "TypeRef", kind: struct, fields: [(name: "name", ty: "Ident")]),
        (name: "Ident", kind: struct, fields: [(name: "text", ty: "String")]),
        (name: "PathLiteral", kind: struct, fields: [(name: "raw_text", ty: "String")]),
        (name: "Expr", kind: enum, variants: [
            (name: "NameRef", ty: "NameRef"),
            (name: "Literal", ty: "Literal"),
            (name: "List", ty: "List"),
            (name: "Paren", ty: "Paren"),
            (name: "Call", ty: "Call"),
            (name: "Prefix", ty: "Prefix"),
            (name: "Binary", ty: "Binary"),
        ]),
        (name: "NameRef", kind: struct, fields: [(name: "name", ty: "Ident")]),
        (name: "Literal", kind: enum, variants: [
            (name: "String"),
            (name: "Int"),
            (name: "Float"),
            (name: "Bool"),
            (name: "Color"),
            (name: "Duration"),
        ]),
        (name: "List", kind: struct, fields: [(name: "items", ty: "Vec<Expr>")]),
        (name: "Paren", kind: struct, fields: [(name: "expr", ty: "Expr")]),
        (name: "Call", kind: struct, fields: [
            (name: "callee", ty: "Expr"),
            (name: "args", ty: "Vec<Expr>"),
        ]),
        (name: "Prefix", kind: struct, fields: [(name: "expr", ty: "Expr")]),
        (name: "Binary", kind: struct, fields: [
            (name: "left", ty: "Expr"),
            (name: "right", ty: "Expr"),
        ]),
    ],
    lower: [
        (syntax: "SourceFile", hir: "SourceFile", fields: [
            (name: "imports", accessor: "imports"),
            (name: "document", accessor: "document"),
        ]),
        (syntax: "ImportDecl", hir: "Import", fields: [
            (name: "kind", accessor: "kind"),
            (name: "name", accessor: "name"),
            (name: "path", accessor: "path"),
        ]),
        (syntax: "Document", hir: "Document", fields: [
            (name: "kind", accessor: "kind"),
            (name: "name", accessor: "name"),
            (name: "block", accessor: "block"),
        ]),
        (syntax: "Block", hir: "Block", fields: [(name: "items", accessor: "items")]),
        (syntax: "FnDecl", hir: "FnDecl", fields: [
            (name: "name", accessor: "name"),
            (name: "params", accessor: "params"),
            (name: "return_type", accessor: "return_type"),
            (name: "body", accessor: "body"),
        ]),
        (syntax: "Param", hir: "Param", fields: [
            (name: "name", accessor: "name"),
            (name: "ty", accessor: "ty"),
        ]),
        (syntax: "LetStmt", hir: "LetStmt", fields: [
            (name: "name", accessor: "name"),
            (name: "ty", accessor: "ty"),
            (name: "value", accessor: "value"),
        ]),
        (syntax: "Command", hir: "Command", fields: [
            (name: "head", accessor: "head"),
            (name: "args", accessor: "args"),
            (name: "initializer", accessor: "initializer"),
            (name: "body", accessor: "body"),
        ]),
        (syntax: "TypeRef", hir: "TypeRef", fields: [(name: "name", accessor: "name")]),
        (syntax: "Name", hir: "Ident", fields: [(name: "text", accessor: "text")]),
        (syntax: "PathLit", hir: "PathLiteral", fields: [(name: "raw_text", accessor: "raw_text")]),
        (syntax: "NameRef", hir: "NameRef", fields: [(name: "name", accessor: "name")]),
        (syntax: "ListExpr", hir: "List", fields: [(name: "items", accessor: "items")]),
        (syntax: "ParenExpr", hir: "Paren", fields: [(name: "expr", accessor: "expr")]),
        (syntax: "CallExpr", hir: "Call", fields: [
            (name: "callee", accessor: "callee"),
            (name: "args", accessor: "args"),
        ]),
        (syntax: "PrefixExpr", hir: "Prefix", fields: [
            (name: "op", accessor: "op"),
            (name: "expr", accessor: "expr"),
        ]),
        (syntax: "BinaryExpr", hir: "Binary", fields: [
            (name: "left", accessor: "left"),
            (name: "op", accessor: "op"),
            (name: "right", accessor: "right"),
        ]),
    ],
    operators: (
        prefix: [
            (token: "Minus", variant: "Neg"),
            (token: "Bang", variant: "Not"),
        ],
        binary: [
            (token: "OrOr", variant: "LogicalOr"),
            (token: "AndAnd", variant: "LogicalAnd"),
            (token: "Pipe", variant: "BitOr"),
            (token: "Caret", variant: "BitXor"),
            (token: "Ampersand", variant: "BitAnd"),
            (token: "EqEq", variant: "Eq"),
            (token: "BangEq", variant: "NotEq"),
            (token: "Lt", variant: "Lt"),
            (token: "Le", variant: "Le"),
            (token: "Gt", variant: "Gt"),
            (token: "Ge", variant: "Ge"),
            (token: "DotDot", variant: "Range"),
            (token: "Shl", variant: "Shl"),
            (token: "Shr", variant: "Shr"),
            (token: "Plus", variant: "Add"),
            (token: "Minus", variant: "Sub"),
            (token: "Star", variant: "Mul"),
            (token: "Slash", variant: "Div"),
            (token: "Percent", variant: "Rem"),
            (token: "StarStar", variant: "Pow"),
        ],
    ),
)

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dawn",
  "version": "0.1.0",
  "identifier": "app.dawn.desktop",
  "build": {
    "beforeDevCommand": "pnpm exec vite --host 127.0.0.1 --port 1430 --strictPort",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dawn",
        "width": 1280,
        "height": 820,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}

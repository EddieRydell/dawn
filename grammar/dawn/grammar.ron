(
    language: (
        type_name: "DawnLanguage",
        syntax_kind: "SyntaxKind",
    ),

    diagnostics: (
        invalid_token: "InvalidToken",
        unexpected_token: "UnexpectedToken",
        unexpected_eof: "UnexpectedEof",
        kinds: [
            (name: "InvalidToken", message: "invalid token"),
            (name: "InvalidColor", message: "invalid color literal"),
            (name: "InvalidInt", message: "invalid integer literal"),
            (name: "InvalidFloat", message: "invalid float literal"),
            (name: "UnterminatedBlockComment", message: "unterminated block comment"),
            (name: "UnexpectedToken", message: "unexpected token"),
            (name: "UnexpectedEof", message: "unexpected end of file"),
        ],
    ),

    tokens: (
        rules: [
            (name: "Whitespace", regex: "[ \\t\\r\\n\\f]+", trivia: skip),
            (name: "LineComment", regex: "//[^\\n]*", trivia: emit),
            (name: "BlockComment", start: "/*", end: "*/", trivia: emit, diagnostic: "UnterminatedBlockComment"),

            (name: "ProjectKw", literal: "project"),
            (name: "DisplayKw", literal: "display"),
            (name: "HardwareKw", literal: "hardware"),
            (name: "LayoutKw", literal: "layout"),
            (name: "PatchKw", literal: "patch"),
            (name: "SequenceKw", literal: "sequence"),
            (name: "CurveKw", literal: "curve"),
            (name: "EffectKw", literal: "effect"),
            (name: "EventKw", literal: "event"),
            (name: "ImportKw", literal: "import"),
            (name: "FromKw", literal: "from"),
            (name: "VersionKw", literal: "version"),
            (name: "LabelKw", literal: "label"),
            (name: "DescriptionKw", literal: "description"),
            (name: "ControllerKw", literal: "controller"),
            (name: "InputKw", literal: "input"),
            (name: "OutputKw", literal: "output"),
            (name: "UniverseKw", literal: "universe"),
            (name: "FixtureKw", literal: "fixture"),
            (name: "GroupKw", literal: "group"),
            (name: "MembersKw", literal: "members"),
            (name: "FilterKw", literal: "filter"),
            (name: "RouteKw", literal: "route"),
            (name: "TargetKw", literal: "target"),
            (name: "AtKw", literal: "at"),
            (name: "ForKw", literal: "for"),
            (name: "DurationKw", literal: "duration"),
            (name: "FrameRateKw", literal: "frame_rate"),
            (name: "AudioKw", literal: "audio"),
            (name: "RangeKw", literal: "range"),
            (name: "KeyKw", literal: "key"),
            (name: "EnumKw", literal: "enum"),
            (name: "FlagsKw", literal: "flags"),
            (name: "ParamKw", literal: "param"),
            (name: "SpatialKw", literal: "spatial"),
            (name: "FnKw", literal: "fn"),
            (name: "LetKw", literal: "let"),
            (name: "IfKw", literal: "if"),
            (name: "ElseKw", literal: "else"),
            (name: "SwitchKw", literal: "switch"),
            (name: "CaseKw", literal: "case"),
            (name: "DefaultKw", literal: "default"),
            (name: "TrueKw", literal: "true"),
            (name: "FalseKw", literal: "false"),
            (name: "FloatKw", literal: "float"),
            (name: "IntKw", literal: "int"),
            (name: "BoolKw", literal: "bool"),
            (name: "ColorKw", literal: "color"),
            (name: "GradientKw", literal: "gradient"),
            (name: "PathKw", literal: "path"),
            (name: "VirtualStringKw", literal: "virtual_string"),
            (name: "MillisecondsKw", literal: "ms"),
            (name: "SecondsKw", literal: "s"),
            (name: "MinutesKw", literal: "m"),

            (name: "Ident", regex: "[A-Za-z_][A-Za-z0-9_]*"),
            (name: "String", regex: "\"[^\"]*\""),
            (name: "Color", regex: "#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?"),
            (name: "InvalidColor", regex: "#[0-9A-Za-z]*", diagnostic: "InvalidColor"),
            (name: "Float", regex: "(([0-9][0-9_]*\\.[0-9_]*|\\.[0-9][0-9_]*)([eE][+-]?[0-9][0-9_]*)?|[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*)"),
            (name: "Int", regex: "[0-9][0-9_]*"),

            (name: "StarStar", literal: "**"),
            (name: "EqEq", literal: "=="),
            (name: "BangEq", literal: "!="),
            (name: "Le", literal: "<="),
            (name: "Ge", literal: ">="),
            (name: "AndAnd", literal: "&&"),
            (name: "OrOr", literal: "||"),
            (name: "Shl", literal: "<<"),
            (name: "Shr", literal: ">>"),
            (name: "LBrace", literal: "{"),
            (name: "RBrace", literal: "}"),
            (name: "LBracket", literal: "["),
            (name: "RBracket", literal: "]"),
            (name: "LParen", literal: "("),
            (name: "RParen", literal: ")"),
            (name: "Lt", literal: "<"),
            (name: "Gt", literal: ">"),
            (name: "Colon", literal: ":"),
            (name: "Comma", literal: ","),
            (name: "Semicolon", literal: ";"),
            (name: "Dot", literal: "."),
            (name: "Eq", literal: "="),
            (name: "Plus", literal: "+"),
            (name: "Minus", literal: "-"),
            (name: "Star", literal: "*"),
            (name: "Slash", literal: "/"),
            (name: "Percent", literal: "%"),
            (name: "Pipe", literal: "|"),
            (name: "Ampersand", literal: "&"),
            (name: "Caret", literal: "^"),
            (name: "Bang", literal: "!"),
            (name: "Question", literal: "?"),
        ],
    ),

    syntax: (
        entry: "SourceFile",
        nodes: [
            "SourceFile",
            "ImportDecl",
            "Document",
            "DocKind",
            "Name",
            "PathLit",
            "BalancedBlock",
            "BalancedItem",
        ],
        rules: [
            (
                name: "SourceFile",
                pattern: [
                    (repeat: "ImportDecl"),
                    (node: "Document"),
                ],
            ),
            (
                name: "ImportDecl",
                pattern: [
                    (token: "ImportKw"),
                    (node: "DocKind"),
                    (node: "Name"),
                    (token: "FromKw"),
                    (node: "PathLit"),
                    (token: "Semicolon"),
                ],
            ),
            (
                name: "Document",
                pattern: [
                    (node: "DocKind"),
                    (node: "Name"),
                    (node: "BalancedBlock"),
                ],
            ),
            (
                name: "DocKind",
                pattern: [
                    (choice: [
                        (token: "ProjectKw"),
                        (token: "DisplayKw"),
                        (token: "HardwareKw"),
                        (token: "LayoutKw"),
                        (token: "PatchKw"),
                        (token: "SequenceKw"),
                        (token: "CurveKw"),
                        (token: "EffectKw"),
                    ]),
                ],
            ),
            (name: "Name", pattern: [(token: "Ident")]),
            (
                name: "PathLit",
                pattern: [
                    (token: "Lt"),
                    (repeat: "PathToken"),
                    (token: "Gt"),
                ],
            ),
            (
                name: "BalancedBlock",
                pattern: [
                    (token: "LBrace"),
                    (repeat: "BalancedItem"),
                    (token: "RBrace"),
                ],
            ),
            (
                name: "BalancedItem",
                pattern: [
                    (choice: [
                        (node: "BalancedBlock"),
                        (token_set: "AnyTokenExceptBrace"),
                    ]),
                ],
            ),
        ],
        token_sets: [
            (
                name: "PathToken",
                tokens: [
                    "Ident", "String", "Color", "Float", "Int",
                    "ProjectKw", "DisplayKw", "HardwareKw", "LayoutKw", "PatchKw",
                    "SequenceKw", "CurveKw", "EffectKw", "EventKw", "ImportKw", "FromKw",
                    "VersionKw", "LabelKw", "DescriptionKw", "ControllerKw", "InputKw",
                    "OutputKw", "UniverseKw", "FixtureKw", "GroupKw", "MembersKw",
                    "FilterKw", "RouteKw", "TargetKw", "AtKw", "ForKw", "DurationKw",
                    "FrameRateKw", "AudioKw", "RangeKw", "KeyKw", "EnumKw", "FlagsKw",
                    "ParamKw", "SpatialKw", "FnKw", "LetKw", "IfKw", "ElseKw",
                    "SwitchKw", "CaseKw", "DefaultKw", "TrueKw", "FalseKw", "FloatKw",
                    "IntKw", "BoolKw", "ColorKw", "GradientKw", "PathKw", "VirtualStringKw",
                    "MillisecondsKw", "SecondsKw", "MinutesKw", "LBracket", "RBracket",
                    "LParen", "RParen", "Colon", "Comma", "Semicolon", "Dot", "Eq",
                    "Plus", "Minus", "Star", "Slash", "Percent", "Pipe", "Ampersand",
                    "Caret", "Bang", "Question", "StarStar", "EqEq", "BangEq", "Le",
                    "Ge", "AndAnd", "OrOr",
                ],
            ),
            (
                name: "AnyTokenExceptBrace",
                include: "all_tokens",
                exclude: ["LBrace", "RBrace"],
            ),
        ],
    ),

    expressions: (
        items: [],
    ),

    ast: (
        root: "SourceFile",
        nodes: [
            (
                name: "SourceFile",
                syntax: "SourceFile",
                accessors: [
                    (name: "imports", kind: "children", node: "ImportDecl"),
                    (name: "document", kind: "child", node: "Document"),
                ],
            ),
            (
                name: "ImportDecl",
                syntax: "ImportDecl",
                accessors: [
                    (name: "kind", kind: "child", node: "DocKind"),
                    (name: "name", kind: "child", node: "Name"),
                    (name: "path", kind: "child", node: "PathLit"),
                ],
            ),
            (
                name: "Document",
                syntax: "Document",
                accessors: [
                    (name: "kind", kind: "child", node: "DocKind"),
                    (name: "name", kind: "child", node: "Name"),
                    (name: "block", kind: "child", node: "BalancedBlock"),
                ],
            ),
            (
                name: "DocKind",
                syntax: "DocKind",
                accessors: [(name: "token", kind: "first_token")],
            ),
            (
                name: "Name",
                syntax: "Name",
                accessors: [(name: "ident", kind: "token", token: "Ident")],
            ),
            (
                name: "PathLit",
                syntax: "PathLit",
                accessors: [(name: "raw_text", kind: "text_between", start: "Lt", end: "Gt")],
            ),
            (
                name: "BalancedBlock",
                syntax: "BalancedBlock",
                accessors: [(name: "items", kind: "children", node: "BalancedItem")],
            ),
            (
                name: "BalancedItem",
                syntax: "BalancedItem",
                accessors: [],
            ),
        ],
        enums: [
            (
                name: "DocKindValue",
                from_node: "DocKind",
                variants: [
                    ("Project", "ProjectKw"),
                    ("Display", "DisplayKw"),
                    ("Hardware", "HardwareKw"),
                    ("Layout", "LayoutKw"),
                    ("Patch", "PatchKw"),
                    ("Sequence", "SequenceKw"),
                    ("Curve", "CurveKw"),
                    ("Effect", "EffectKw"),
                ],
            ),
        ],
    ),
)

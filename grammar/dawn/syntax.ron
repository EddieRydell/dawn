(
    entry: "SourceFile",

    doc_kinds: [
        ("Project", "ProjectKw"),
        ("Display", "DisplayKw"),
        ("Hardware", "HardwareKw"),
        ("Layout", "LayoutKw"),
        ("Patch", "PatchKw"),
        ("Sequence", "SequenceKw"),
        ("Curve", "CurveKw"),
        ("Effect", "EffectKw"),
    ],

    nodes: [
        "SourceFile",
        "ImportDecl",
        "Document",
        "DocKind",
        "Name",
        "PathLit",
        "BalancedBlock",
        "BalancedItem",
    ],

    rules: [
        (
            name: "SourceFile",
            pattern: [
                (repeat: "ImportDecl"),
                (node: "Document"),
            ],
        ),
        (
            name: "ImportDecl",
            pattern: [
                (token: "ImportKw"),
                (node: "DocKind"),
                (node: "Name"),
                (token: "FromKw"),
                (node: "PathLit"),
                (token: "Semicolon"),
            ],
        ),
        (
            name: "Document",
            pattern: [
                (node: "DocKind"),
                (node: "Name"),
                (node: "BalancedBlock"),
            ],
        ),
        (
            name: "DocKind",
            pattern: [
                (choice: [
                    (token: "ProjectKw"),
                    (token: "DisplayKw"),
                    (token: "HardwareKw"),
                    (token: "LayoutKw"),
                    (token: "PatchKw"),
                    (token: "SequenceKw"),
                    (token: "CurveKw"),
                    (token: "EffectKw"),
                ]),
            ],
        ),
        (
            name: "Name",
            pattern: [
                (token: "Ident"),
            ],
        ),
        (
            name: "PathLit",
            pattern: [
                (token: "Lt"),
                (repeat: "PathToken"),
                (token: "Gt"),
            ],
        ),
        (
            name: "BalancedBlock",
            pattern: [
                (token: "LBrace"),
                (repeat: "BalancedItem"),
                (token: "RBrace"),
            ],
        ),
        (
            name: "BalancedItem",
            pattern: [
                (choice: [
                    (node: "BalancedBlock"),
                    (token_set: "AnyTokenExceptBrace"),
                ]),
            ],
        ),
    ],

    token_sets: [
        (
            name: "PathToken",
            tokens: [
                "Ident",
                "String",
                "Color",
                "Float",
                "Int",
                "ProjectKw",
                "DisplayKw",
                "HardwareKw",
                "LayoutKw",
                "PatchKw",
                "SequenceKw",
                "CurveKw",
                "EffectKw",
                "EventKw",
                "ImportKw",
                "FromKw",
                "VersionKw",
                "LabelKw",
                "DescriptionKw",
                "ControllerKw",
                "InputKw",
                "OutputKw",
                "UniverseKw",
                "FixtureKw",
                "GroupKw",
                "MembersKw",
                "FilterKw",
                "RouteKw",
                "TargetKw",
                "AtKw",
                "ForKw",
                "DurationKw",
                "FrameRateKw",
                "AudioKw",
                "RangeKw",
                "KeyKw",
                "EnumKw",
                "FlagsKw",
                "ParamKw",
                "SpatialKw",
                "FnKw",
                "LetKw",
                "IfKw",
                "ElseKw",
                "SwitchKw",
                "CaseKw",
                "DefaultKw",
                "TrueKw",
                "FalseKw",
                "FloatKw",
                "IntKw",
                "BoolKw",
                "ColorKw",
                "GradientKw",
                "PathKw",
                "VirtualStringKw",
                "MillisecondsKw",
                "SecondsKw",
                "MinutesKw",
                "LBracket",
                "RBracket",
                "LParen",
                "RParen",
                "Colon",
                "Comma",
                "Semicolon",
                "Dot",
                "Eq",
                "Plus",
                "Minus",
                "Star",
                "Slash",
                "Percent",
                "Pipe",
                "Ampersand",
                "Caret",
                "Bang",
                "Question",
                "StarStar",
                "EqEq",
                "BangEq",
                "Le",
                "Ge",
                "AndAnd",
                "OrOr",
            ],
        ),
        (
            name: "AnyTokenExceptBrace",
            include: "all_tokens",
            exclude: [
                "LBrace",
                "RBrace",
            ],
        ),
    ],

    recovery: [
        (
            rule: "SourceFile",
            strategy: "recover_until_doc_or_eof",
        ),
        (
            rule: "ImportDecl",
            strategy: "recover_until_semicolon_or_doc",
        ),
        (
            rule: "BalancedBlock",
            strategy: "recover_until_matching_brace_or_eof",
        ),
    ],
)

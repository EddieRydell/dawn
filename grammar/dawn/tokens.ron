(
    trivia: [
        (
            name: "Whitespace",
            pattern: "[ \\t\\r\\n\\f]+",
            skip: true,
        ),
        (
            name: "LineComment",
            pattern: "//[^\\n]*",
            skip: false,
        ),
        (
            name: "BlockComment",
            start: "/*",
            end: "*/",
            skip: false,
            error: "UnterminatedBlockComment",
        ),
    ],

    keywords: [
        ("ProjectKw", "project"),
        ("DisplayKw", "display"),
        ("HardwareKw", "hardware"),
        ("LayoutKw", "layout"),
        ("PatchKw", "patch"),
        ("SequenceKw", "sequence"),
        ("CurveKw", "curve"),
        ("EffectKw", "effect"),
        ("EventKw", "event"),
        ("ImportKw", "import"),
        ("FromKw", "from"),
        ("VersionKw", "version"),
        ("LabelKw", "label"),
        ("DescriptionKw", "description"),
        ("ControllerKw", "controller"),
        ("InputKw", "input"),
        ("OutputKw", "output"),
        ("UniverseKw", "universe"),
        ("FixtureKw", "fixture"),
        ("GroupKw", "group"),
        ("MembersKw", "members"),
        ("FilterKw", "filter"),
        ("RouteKw", "route"),
        ("TargetKw", "target"),
        ("AtKw", "at"),
        ("ForKw", "for"),
        ("DurationKw", "duration"),
        ("FrameRateKw", "frame_rate"),
        ("AudioKw", "audio"),
        ("RangeKw", "range"),
        ("KeyKw", "key"),
        ("EnumKw", "enum"),
        ("FlagsKw", "flags"),
        ("ParamKw", "param"),
        ("SpatialKw", "spatial"),
        ("FnKw", "fn"),
        ("LetKw", "let"),
        ("IfKw", "if"),
        ("ElseKw", "else"),
        ("SwitchKw", "switch"),
        ("CaseKw", "case"),
        ("DefaultKw", "default"),
        ("TrueKw", "true"),
        ("FalseKw", "false"),
        ("FloatKw", "float"),
        ("IntKw", "int"),
        ("BoolKw", "bool"),
        ("ColorKw", "color"),
        ("GradientKw", "gradient"),
        ("PathKw", "path"),
        ("VirtualStringKw", "virtual_string"),
        ("MillisecondsKw", "ms"),
        ("SecondsKw", "s"),
        ("MinutesKw", "m"),
    ],

    literals: [
        (
            name: "Ident",
            pattern: "[A-Za-z_][A-Za-z0-9_]*",
            value: "text",
        ),
        (
            name: "String",
            // Display-only text. A quote closes the string; everything else is
            // accepted literally, including backslashes and newlines.
            pattern: "\"[^\"]*\"",
            value: "text",
        ),
        (
            name: "Color",
            pattern: "#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?",
            value: "text",
        ),
        (
            name: "InvalidColor",
            pattern: "#[0-9A-Za-z]*",
            error: "InvalidColor",
        ),
        (
            name: "Float",
            patterns: [
                "([0-9][0-9_]*\\.[0-9_]*|\\.[0-9][0-9_]*)([eE][+-]?[0-9][0-9_]*)?",
                "[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*",
            ],
            value: "text",
        ),
        (
            name: "Int",
            pattern: "[0-9][0-9_]*",
            value: "i64",
            normalize: "remove_underscores",
            error: "InvalidInt",
        ),
    ],

    punctuation: [
        ("StarStar", "**"),
        ("EqEq", "=="),
        ("BangEq", "!="),
        ("Le", "<="),
        ("Ge", ">="),
        ("AndAnd", "&&"),
        ("OrOr", "||"),
        ("Shl", "<<"),
        ("Shr", ">>"),
        ("LBrace", "{"),
        ("RBrace", "}"),
        ("LBracket", "["),
        ("RBracket", "]"),
        ("LParen", "("),
        ("RParen", ")"),
        ("Lt", "<"),
        ("Gt", ">"),
        ("Colon", ":"),
        ("Comma", ","),
        ("Semicolon", ";"),
        ("Dot", "."),
        ("Eq", "="),
        ("Plus", "+"),
        ("Minus", "-"),
        ("Star", "*"),
        ("Slash", "/"),
        ("Percent", "%"),
        ("Pipe", "|"),
        ("Ampersand", "&"),
        ("Caret", "^"),
        ("Bang", "!"),
        ("Question", "?"),
    ],

    errors: [
        "InvalidToken",
        "InvalidColor",
        "InvalidInt",
        "InvalidFloat",
        "UnterminatedBlockComment",
    ],
)

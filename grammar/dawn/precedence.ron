(
    // Expression grammar is not active in the top-level CST parser yet. These
    // tiers capture the current intended operator inventory for future Pratt
    // parser generation.
    tiers: [
        (name: "Or", associativity: "left", operators: ["OrOr"]),
        (name: "And", associativity: "left", operators: ["AndAnd"]),
        (name: "BitOr", associativity: "left", operators: ["Pipe"]),
        (name: "BitXor", associativity: "left", operators: ["Caret"]),
        (name: "BitAnd", associativity: "left", operators: ["Ampersand"]),
        (name: "Equality", associativity: "left", operators: ["EqEq", "BangEq"]),
        (name: "Comparison", associativity: "left", operators: ["Lt", "Le", "Gt", "Ge"]),
        (name: "Shift", associativity: "left", operators: ["Shl", "Shr"]),
        (name: "Add", associativity: "left", operators: ["Plus", "Minus"]),
        (name: "Mul", associativity: "left", operators: ["Star", "Slash", "Percent"]),
        (name: "Pow", associativity: "right", operators: ["StarStar"]),
    ],

    prefix: [
        ("Not", "Bang"),
        ("Negate", "Minus"),
    ],

    postfix: [
        "Call",
        "Field",
    ],
)

(
  language: "Dawn",
  version: 1,

  lexical: (
    trivia: [
      (name: "Whitespace", logos: r"[ \t\r\n\f]+", skip: true),
      (name: "LineComment", logos: r"//[^\n]*", skip: true),
    ],

    tokens: [
      (name: "Ident", kind: "regex", logos: r"[A-Za-z_][A-Za-z0-9_]*", value: "String"),
      (name: "String", kind: "regex", logos: r#""([^"\\\n\r]|\\.)*""#, value: "String"),
      (name: "Color", kind: "regex", logos: r"#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?", value: "ColorLiteral"),
      (name: "Float", kind: "regex", logos: r"[0-9]+\.[0-9]+", value: "f64"),
      (name: "Int", kind: "regex", logos: r"[0-9]+", value: "i64"),

      // Operators and punctuation. Longer tokens must be emitted before prefixes.
      (name: "StarStar", kind: "literal", text: "**"),
      (name: "EqEq", kind: "literal", text: "=="),
      (name: "BangEq", kind: "literal", text: "!="),
      (name: "Le", kind: "literal", text: "<="),
      (name: "Ge", kind: "literal", text: ">="),
      (name: "AndAnd", kind: "literal", text: "&&"),
      (name: "OrOr", kind: "literal", text: "||"),
      (name: "Shl", kind: "literal", text: "<<"),
      (name: "Shr", kind: "literal", text: ">>"),
      (name: "Arrow", kind: "literal", text: "->"),
      (name: "FatArrow", kind: "literal", text: "=>"),
      (name: "LBrace", kind: "literal", text: "{"),
      (name: "RBrace", kind: "literal", text: "}"),
      (name: "LBracket", kind: "literal", text: "["),
      (name: "RBracket", kind: "literal", text: "]"),
      (name: "LParen", kind: "literal", text: "("),
      (name: "RParen", kind: "literal", text: ")"),
      (name: "Lt", kind: "literal", text: "<"),
      (name: "Gt", kind: "literal", text: ">"),
      (name: "Colon", kind: "literal", text: ":"),
      (name: "Comma", kind: "literal", text: ","),
      (name: "Semicolon", kind: "literal", text: ";"),
      (name: "Dot", kind: "literal", text: "."),
      (name: "Eq", kind: "literal", text: "="),
      (name: "Plus", kind: "literal", text: "+"),
      (name: "Minus", kind: "literal", text: "-"),
      (name: "Star", kind: "literal", text: "*"),
      (name: "Slash", kind: "literal", text: "/"),
      (name: "Percent", kind: "literal", text: "%"),
      (name: "Pipe", kind: "literal", text: "|"),
      (name: "Ampersand", kind: "literal", text: "&"),
      (name: "Caret", kind: "literal", text: "^"),
      (name: "Bang", kind: "literal", text: "!"),
      (name: "Question", kind: "literal", text: "?"),
      (name: "Eof", kind: "synthetic"),
    ],

    contextual_keywords: [
      "project", "display", "hardware", "layout", "patch", "sequence", "curve", "effect",
      "import", "from", "version", "label", "description",
      "controller", "input", "output", "universe", "fixture", "group", "members",
      "filter", "route", "target", "at", "for", "duration", "frame_rate", "audio",
      "range", "key", "enum", "flags", "param", "spatial", "fn", "let",
      "if", "else", "switch", "case", "default", "true", "false",
      "float", "int", "bool", "color", "gradient", "path",
    ],
  ),

  syntax: (
    start: "SourceFile",

    documents: [
      "ProjectDoc",
      "DisplayDoc",
      "HardwareDoc",
      "LayoutDoc",
      "PatchDoc",
      "SequenceDoc",
      "CurveDoc",
      "EffectDoc",
    ],

    ast_nodes: [
      "SourceFile", "ImportDecl", "ProjectDocument",
      "ProjectDoc", "DisplayDoc", "HardwareDoc", "ControllerDecl", "InputDecl", "OutputDecl",
      "UniverseDecl", "LayoutDoc", "FixtureDecl", "GroupDecl", "PatchDoc", "FilterDecl",
      "RouteDecl", "SequenceDoc", "EventDecl", "CurveDoc", "CurveKeyDecl", "EffectDoc",
      "EnumDecl", "FlagsDecl", "ParamDecl", "FnDecl", "FnParam", "LetDecl",
      "Expr", "Pattern", "ValueExpr", "TypeRef", "ParamType", "QualifiedName", "PathLit",
    ],

    productions: [
      (name: "SourceFile", rule: r#"{ ImportDecl } Document Eof"#),

      (name: "Document", rule: r#"ProjectDoc | DisplayDoc | HardwareDoc | LayoutDoc | PatchDoc | SequenceDoc | CurveDoc | EffectDoc"#),
      (name: "DocKind", rule: r#""project" | "display" | "sequence" | "hardware" | "layout" | "patch" | "curve" | "effect""#),
      (name: "DocName", rule: r#"Ident"#),
      (name: "BoolLit", rule: r#""true" | "false""#),
      (name: "NumberLit", rule: r#"Float | Int"#),
      (name: "VersionDecl", rule: r#""version" Int Semicolon"#),
      (name: "LabelDecl", rule: r#""label" String Semicolon"#),
      (name: "DescriptionDecl", rule: r#""description" String Semicolon"#),
      (name: "DisplayTextDecl", rule: r#"LabelDecl | DescriptionDecl"#),
      (name: "ImportDecl", rule: r#""import" DocKind DocName "from" PathLit Semicolon"#),

      // Path literals are parser-level so '<...>' paths do not conflict with generic types.
      (name: "PathLit", rule: r#"Lt PathBody Gt"#),
      (name: "PathBody", rule: r#"{ Ident | Int | Float | String | Dot | Slash | Minus | Plus | Percent | Colon | Ampersand | Pipe | Caret | Question | Eq | Bang | Star }"#),

      (name: "QualifiedName", rule: r#"Ident { Dot Ident }"#),

      (name: "ProjectDoc", rule: r#""project" DocName LBrace VersionDecl { DisplayTextDecl | ProjectField } RBrace"#),
      (name: "ProjectField", rule: r#""display" QualifiedName Semicolon | "sequence" QualifiedName Semicolon"#),

      (name: "DisplayDoc", rule: r#""display" DocName LBrace VersionDecl { DisplayTextDecl | DisplayField } RBrace"#),
      (name: "DisplayField", rule: r#""hardware" QualifiedName Semicolon | "layout" QualifiedName Semicolon | "patch" QualifiedName Semicolon"#),

      (name: "HardwareDoc", rule: r#""hardware" DocName LBrace VersionDecl { DisplayTextDecl | ControllerDecl } RBrace"#),
      (name: "ControllerDecl", rule: r#""controller" DocName LBrace { DisplayTextDecl | ControllerField | InputDecl | OutputDecl } RBrace"#),
      (name: "ControllerField", rule: r#""vendor" Ident Semicolon | "model" Ident Semicolon | "variant" Ident Semicolon"#),

      (name: "InputDecl", rule: r#""input" DocName LBrace { DisplayTextDecl | InputField | UniverseDecl } RBrace"#),
      (name: "InputField", rule: r#""type" InputType Semicolon | "port" Int Semicolon | "priority" Int Semicolon | "sync_universe" Int Semicolon | "address" AddressLit Semicolon | "destination" Int Semicolon | "channel_count" Int Semicolon | "channels_per_packet" Int Semicolon | "keep_channel_numbers" BoolLit Semicolon | "byte_offset" Int Semicolon | "device" PathLit Semicolon | "baud" Int Semicolon | "data_bits" Int Semicolon | "parity" Ident Semicolon | "stop_bits" Int Semicolon | "protocol" SerialProtocol Semicolon"#),
      (name: "InputType", rule: r#""e131" | "artnet" | "ddp" | "serial""#),
      (name: "SerialProtocol", rule: r#""dmx" | "opendmx" | "renard" | "lor" | "dlight" | "pixelnet" | "generic_serial""#),
      (name: "UniverseDecl", rule: r#""universe" DocName LBrace { DisplayTextDecl | UniverseField } RBrace"#),
      (name: "UniverseField", rule: r#""id" Int Semicolon | "net" Int Semicolon | "subnet" Int Semicolon | "start_channel" Int Semicolon | "channels" Int Semicolon | "address" AddressLit Semicolon | "cast" Ident Semicolon | "enabled" BoolLit Semicolon"#),
      (name: "AddressLit", rule: r#"Int Dot Int Dot Int Dot Int"#),

      (name: "OutputDecl", rule: r#""output" DocName LBrace { DisplayTextDecl | OutputField | VirtualStringDecl } RBrace"#),
      (name: "OutputField", rule: r#""type" OutputType Semicolon | "input" QualifiedName Semicolon | "input_channel" Int Semicolon | "connector" Ident Semicolon | "index" Int Semicolon | "pixel_protocol" Ident Semicolon | "node_count" Int Semicolon | "color_order" Ident Semicolon | "white_mode" Ident Semicolon | "null_nodes" Int Semicolon | "end_null_nodes" Int Semicolon | "group_size" Int Semicolon | "reverse" BoolLit Semicolon | "zigzag" Int Semicolon | "brightness" NumberLit Semicolon | "gamma" NumberLit Semicolon | "color_order_override" Int Int Ident Semicolon | "fixture_profile" Ident Semicolon | "channel_count" Int Semicolon | "fixture_count" Int Semicolon"#),
      (name: "OutputType", rule: r#""pixel_string" | "dmx" | "dumb_rgb" | "dumb_rgbw" | "single_channel""#),
      (name: "VirtualStringDecl", rule: r#""virtual_string" DocName LBrace { DisplayTextDecl | VirtualStringField } RBrace"#),
      (name: "VirtualStringField", rule: r#""input_channel" Int Semicolon | "node_count" Int Semicolon | "color_order" Ident Semicolon | "white_mode" Ident Semicolon | "null_nodes" Int Semicolon | "end_null_nodes" Int Semicolon | "group_size" Int Semicolon | "reverse" BoolLit Semicolon | "zigzag" Int Semicolon | "brightness" NumberLit Semicolon | "gamma" NumberLit Semicolon"#),

      (name: "LayoutDoc", rule: r#""layout" DocName LBrace VersionDecl { DisplayTextDecl | FixtureDecl | GroupDecl } RBrace"#),
      (name: "FixtureDecl", rule: r#""fixture" DocName LBrace { DisplayTextDecl | FixtureField } RBrace"#),
      (name: "FixtureField", rule: r#""shape" ShapeDecl Semicolon | "pixel_count" Int Semicolon"#),
      (name: "ShapeDecl", rule: r#"LineShape | GridShape"#),
      (name: "LineShape", rule: r#""line" LParen "start" Coord Comma "end" Coord RParen"#),
      (name: "GridShape", rule: r#""grid" LParen "top_left" Coord Comma "bottom_right" Coord Comma "columns" Int RParen"#),
      (name: "Coord", rule: r#"LParen NumberLit Comma NumberLit RParen"#),
      (name: "GroupDecl", rule: r#""group" DocName LBrace { DisplayTextDecl | "members" LBracket QualifiedName { Comma QualifiedName } RBracket Semicolon } RBrace"#),

      (name: "PatchDoc", rule: r#""patch" DocName LBrace VersionDecl { DisplayTextDecl | FilterDecl | RouteDecl } RBrace"#),
      (name: "FilterDecl", rule: r#""filter" DocName LBrace { DisplayTextDecl | FilterField } RBrace"#),
      (name: "FilterField", rule: r#""type" Ident Semicolon | "order" Ident Semicolon"#),
      (name: "RouteDecl", rule: r#""route" DocName LBrace { DisplayTextDecl | RouteField } RBrace"#),
      (name: "RouteField", rule: r#""from" RouteEndpoint Semicolon | "from_channel" Int Semicolon | "to" RouteEndpoint Semicolon | "to_channel" Int Semicolon | "channels" Int Semicolon"#),
      (name: "RouteEndpoint", rule: r#"QualifiedName"#),

      (name: "SequenceDoc", rule: r#""sequence" DocName LBrace VersionDecl { DisplayTextDecl | SequenceField | EventDecl } RBrace"#),
      (name: "SequenceField", rule: r#""display" QualifiedName Semicolon | "duration" DurationLit Semicolon | "frame_rate" NumberLit Semicolon | "audio" PathLit Semicolon"#),
      (name: "DurationLit", rule: r#"DurationPart { DurationPart }"#),
      (name: "DurationPart", rule: r#"NumberLit DurationUnit"#),
      (name: "DurationUnit", rule: r#""ms" | "s" | "m""#),
      (name: "EventDecl", rule: r#""event" DocName LBrace { DisplayTextDecl | EventField } RBrace"#),
      (name: "EventField", rule: r#""target" QualifiedName Semicolon | "at" DurationLit "for" DurationLit Semicolon | EffectCallStmt"#),
      (name: "EffectCallStmt", rule: r#""effect" QualifiedName LParen [ NamedArgList ] RParen Semicolon"#),
      (name: "NamedArgList", rule: r#"NamedArg { (Comma | Semicolon) NamedArg } [ Comma | Semicolon ]"#),
      (name: "NamedArg", rule: r#"Ident ValueExpr"#),

      (name: "CurveDoc", rule: r#""curve" DocName LBrace VersionDecl { DisplayTextDecl | CurveField | CurveKeyDecl } RBrace"#),
      (name: "CurveField", rule: r#""range" CurveValueType Semicolon"#),
      (name: "CurveKeyDecl", rule: r#""key" NumberLit CurveKeyValue [ Ident ] Semicolon"#),
      (name: "CurveKeyValue", rule: r#"NumberLit | Color | BoolLit | QualifiedName"#),
      (name: "CurveValueType", rule: r#"RangedFloatType | RangedIntType | "float" | "int" | "bool" | "color""#),

      (name: "EffectDoc", rule: r#""effect" DocName LBrace VersionDecl { DisplayTextDecl | EffectItem } Expr RBrace"#),
      (name: "EffectItem", rule: r#""spatial" BoolLit Semicolon | EnumDecl | FlagsDecl | ParamDecl | FnDecl | LetDecl"#),
      (name: "EnumDecl", rule: r#""enum" Ident LBrace Ident { Comma Ident } RBrace"#),
      (name: "FlagsDecl", rule: r#""flags" Ident LBrace Ident { Comma Ident } RBrace"#),
      (name: "ParamDecl", rule: r#""param" Ident Colon ParamType [ Eq ValueExpr ] Semicolon"#),
      (name: "ParamType", rule: r#"RangedFloatType | RangedIntType | "bool" | "color" | "gradient" | "path" | CurveType | Ident"#),
      (name: "CurveType", rule: r#""curve" [ Lt CurveValueType Gt ]"#),
      (name: "RangedFloatType", rule: r#""float" LParen Float Comma Float RParen"#),
      (name: "RangedIntType", rule: r#""int" LParen Int Comma Int RParen"#),
      (name: "FnDecl", rule: r#""fn" Ident LParen [ FnParamList ] RParen Colon TypeName LBrace Expr RBrace"#),
      (name: "FnParamList", rule: r#"FnParam { Comma FnParam }"#),
      (name: "FnParam", rule: r#"Ident Colon TypeName"#),
      (name: "TypeName", rule: r#"Ident"#),
      (name: "LetDecl", rule: r#""let" Ident Eq Expr Semicolon"#),

      (name: "ValueExpr", rule: r#"BoolLit | NumberLit | Color | DurationLit | AddressLit | PathLit | QualifiedName | FlagSetExpr"#),
      (name: "FlagSetExpr", rule: r#"QualifiedName { Pipe QualifiedName }"#),

      (name: "Expr", rule: r#"IfExpr | SwitchExpr | LogicalOr"#),
      (name: "IfExpr", rule: r#""if" Expr LBrace Expr RBrace "else" LBrace Expr RBrace"#),
      (name: "SwitchExpr", rule: r#""switch" Expr LBrace { CaseArm } DefaultArm RBrace"#),
      (name: "CaseArm", rule: r#""case" Pattern Colon Expr Semicolon"#),
      (name: "DefaultArm", rule: r#""default" Colon Expr Semicolon"#),
      (name: "Pattern", rule: r#"QualifiedName | NumberLit | BoolLit"#),

      (name: "LogicalOr", rule: r#"LogicalAnd { OrOr LogicalAnd }"#),
      (name: "LogicalAnd", rule: r#"BitwiseOr { AndAnd BitwiseOr }"#),
      (name: "BitwiseOr", rule: r#"BitwiseXor { Pipe BitwiseXor }"#),
      (name: "BitwiseXor", rule: r#"BitwiseAnd { Caret BitwiseAnd }"#),
      (name: "BitwiseAnd", rule: r#"Equality { Ampersand Equality }"#),
      (name: "Equality", rule: r#"Comparison { (EqEq | BangEq) Comparison }"#),
      (name: "Comparison", rule: r#"Additive { (Lt | Le | Gt | Ge) Additive }"#),
      (name: "Additive", rule: r#"Multiplicative { (Plus | Minus) Multiplicative }"#),
      (name: "Multiplicative", rule: r#"Exponent { (Star | Slash | Percent) Exponent }"#),
      (name: "Exponent", rule: r#"Unary [ StarStar Exponent ]"#),
      (name: "Unary", rule: r#"(Bang | Minus) Unary | Postfix"#),
      (name: "Postfix", rule: r#"Primary { CallSuffix | FieldSuffix }"#),
      (name: "CallSuffix", rule: r#"LParen [ ExprList ] RParen"#),
      (name: "FieldSuffix", rule: r#"Dot Ident"#),
      (name: "ExprList", rule: r#"Expr { Comma Expr }"#),
      (name: "Primary", rule: r#"NumberLit | Color | BoolLit | QualifiedName | LParen Expr RParen"#),
    ],

    precedence: [
      (level: 1, assoc: "left", operators: ["OrOr"]),
      (level: 2, assoc: "left", operators: ["AndAnd"]),
      (level: 3, assoc: "left", operators: ["Pipe"]),
      (level: 4, assoc: "left", operators: ["Caret"]),
      (level: 5, assoc: "left", operators: ["Ampersand"]),
      (level: 6, assoc: "left", operators: ["EqEq", "BangEq"]),
      (level: 7, assoc: "left", operators: ["Lt", "Le", "Gt", "Ge"]),
      (level: 8, assoc: "left", operators: ["Plus", "Minus"]),
      (level: 9, assoc: "left", operators: ["Star", "Slash", "Percent"]),
      (level: 10, assoc: "right", operators: ["StarStar"]),
      (level: 11, assoc: "right", operators: ["Bang", "Minus"]),
      (level: 12, assoc: "left", operators: ["CallSuffix", "FieldSuffix"]),
    ],
  ),
)
